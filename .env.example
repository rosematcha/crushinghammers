DISCORD_TOKEN=your-bot-token-here
# Optional: set to 1/true to wipe everyone's hammer counts at startup.
# Useful as a "panic reset" before a redeploy. Unset (or false) for normal operation.
RESET_ON_START=
# Optional one-shot migration: set to 1/true on a single redeploy to clear any
# leftover per-guild slash commands from earlier GUILD_IDS-based deployments.
# Unset afterward so future restarts don't re-run the cleanup.
CLEAR_GUILD_COMMANDS=
