DISCORD_TOKEN=your-bot-token-here
# Comma-separated for multiple servers, e.g. 1369769910208823366,573917368451858473
GUILD_IDS=your-server-id-here
# Optional: set to 1/true to wipe everyone's hammer counts at startup.
# Useful as a "panic reset" before a redeploy. Unset (or false) for normal operation.
RESET_ON_START=
